rules_version = '2';

// 部署：Firebase 控制台 → Firestore → 规则 → 粘贴并发布
// 开发阶段：已登录（含匿名）可读写房间及子集合；上线后请按 hostUid 收紧

service cloud.firestore {
  match /databases/{database}/documents {
    match /rooms/{roomId} {
      allow read, write: if request.auth != null;
    }
    match /rooms/{roomId}/sharedState/{docId} {
      allow read, write: if request.auth != null;
    }
    match /rooms/{roomId}/intents/{intentId} {
      allow read, write: if request.auth != null;
    }
  }
}
